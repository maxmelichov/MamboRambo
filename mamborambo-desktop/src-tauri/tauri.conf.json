{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mamborambo",
  "version": "1.0.6",
  "identifier": "com.maxmelichov.mamborambo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mamborambo",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "deny": [],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns"],
    "externalBin": [
      "binaries/mamborambo-server"
    ],
    "resources": {
      "binaries/libonnxruntime.1.23.2.dylib": "libonnxruntime.1.23.2.dylib"
    }
  }
}
